# API 基础路径（走代理时留空）
VITE_API_BASE_URL=
# Admin 管理服务地址
VITE_API_TARGET=https://localhost:7045
# Auth 认证服务地址
VITE_AUTH_TARGET=https://localhost:7044

# OAuth 客户端 ID
VITE_OAUTH_CLIENT_ID=tpsso_admin_client

# OAuth Scope
VITE_OAUTH_SCOPE=openid profile email roles

# 头像上传允许的 MIME 类型
VITE_AVATAR_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp

# 头像上传大小限制（MB）
VITE_AVATAR_MAX_SIZE_MB=2
