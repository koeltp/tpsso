# API 基础路径（走代理时留空）
VITE_API_BASE_URL=
# Admin 管理服务地址 只在vite.config.ts中使用所以开发环境不要配置 开发环境通过 nginx 反向代理到 adminapi
VITE_API_TARGET=https://localhost:7045


# SSO 前端地址（注册/忘记密码跳转）
VITE_SSO_URL=http://localhost:3010

# OAuth 客户端 ID
VITE_OAUTH_CLIENT_ID=tpsso_admin_client

# OAuth Scope
VITE_OAUTH_SCOPE=openid profile email roles offline_access

# 头像上传允许的 MIME 类型
VITE_AVATAR_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp

# 头像上传大小限制（MB）
VITE_AVATAR_MAX_SIZE_MB=2
