# API 基础路径（走代理时留空；前后端不同域且无代理时填后端地址，如 https://api.example.com）
VITE_API_BASE_URL=
# API 后端地址（生产环境通过 nginx 反向代理）
VITE_API_TARGET=https://tpssoapi.taipi.top

# OAuth 客户端 ID
VITE_OAUTH_CLIENT_ID=tpsso_admin_client

# OAuth Scope
VITE_OAUTH_SCOPE=openid profile email roles

# 头像上传允许的 MIME 类型
VITE_AVATAR_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp

# 头像上传大小限制（MB）
VITE_AVATAR_MAX_SIZE_MB=2
